# Saathi — environment template.
# Copy to .env.local and fill values. .env.local is gitignored.
# The app boots with mocks if these are missing — see MISSING_CREDENTIALS.md.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — one LLM provider, exactly one. Router auto-detects.
# Priority order: explicit LLM_PROVIDER → ANTHROPIC → OPENAI → GROK → OLLAMA.
# ─────────────────────────────────────────────────────────────────────────────

# Cloud providers (any one is enough):
ANTHROPIC_API_KEY=
# OR
OPENAI_API_KEY=
# OR (xAI / Grok via OpenAI-compatible endpoint)
GROK_API_KEY=

# OR — Local Ollama (set LLM_PROVIDER=ollama or OLLAMA_BASE_URL to enable).
# Saathi talks to Ollama's OpenAI-compatible /v1 endpoint.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=gemma4:e4b
# OLLAMA_MODEL_SONNET=gemma4:e4b   # optional per-tier override
# OLLAMA_MODEL_HAIKU=gemma4:e4b    # optional per-tier override

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Supabase (free tier, ~5 minutes on supabase.com, Mumbai region)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Sarvam for production-quality Hindi & 10 regional language voice.
# Without this we fall back to the browser Web Speech API.
# ─────────────────────────────────────────────────────────────────────────────
SARVAM_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# APP CONFIG (defaults work)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Saathi
NEXT_PUBLIC_DEFAULT_LANGUAGE=hi-IN
APP_ENV=development

# auto | anthropic | openai | grok | ollama
LLM_PROVIDER=auto
